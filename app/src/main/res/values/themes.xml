<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.ElectronicMuezzin" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <style name="Theme.ElectronicMuezzin.FullScreen" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:showWhenLocked">true</item>
        <item name="android:turnScreenOn">true</item>
     </style>

    <style name="Theme.ElectronicMuezzin.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0D1B2A</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_mosque</item>
        <item name="postSplashScreenTheme">@style/Theme.ElectronicMuezzin</item>
    </style>

</resources>
